{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "allowJs": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "sfc-oauth/*": ["./sfc-oauth/*"],
      "sfc-common/*": ["./sfc-common/*"]
    }
  },
  "include": ["index.d.ts","**/*.ts", "**/*.d.ts", "**/*.tsx", "**/*.vue", "**/index.ts", "**/index.vue", "sfc-common/index.d.ts"],
  "exclude": ["vite.config.ts", "build/**"],
  "references": [{ "path": "./tsconfig.node.json" }]
}